# Cloudflare Pages headers
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://media.sottospirito.org; media-src 'self' https://media.sottospirito.it; connect-src 'self' https://media.sottospirito.org https://*.r2.cloudflarestorage.com https://api.github.com; frame-src 'none'

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/admin/*
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://media.sottospirito.org https://*.r2.cloudflarestorage.com; media-src 'self' https://media.sottospirito.org; connect-src 'self' https://api.github.com https://media.sottospirito.org https://*.r2.cloudflarestorage.com; frame-src 'none'
