---
/**
 * StickyMiniPlayer — persistent bottom bar that appears when
 * the expanded AudioPlayer scrolls out of viewport.
 * Shares state via Alpine.store('player').
 */
import { UI } from '@/lib/constants';
---

<div
  x-data="stickyMiniPlayer"
  x-show="visible && $store.player.slug"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="translate-y-full"
  x-transition:enter-end="translate-y-0"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="translate-y-0"
  x-transition:leave-end="translate-y-full"
  x-cloak
  role="complementary"
  aria-label={UI.labels.audioControls}
  class="fixed inset-x-0 bottom-0 z-40 border-t border-warm-sand bg-soft-white shadow-lg"
>
  <!-- Thin progress bar at top (draggable) -->
  <div
    class="h-3 -mb-2 cursor-pointer bg-warm-sand relative"
    @mousedown="startDrag($event)"
    @touchstart.passive="startDrag($event)"
  >
    <div
      class="absolute bottom-0 left-0 h-1 bg-terracotta"
      :class="dragging ? '' : 'transition-[width] duration-200'"
      :style="{ width: progressPercent + '%' }"
    ></div>
  </div>

  <div class="mx-auto flex max-w-[var(--max-w-grid)] items-center gap-3 px-4 py-2">
    <!-- Play/Pause button -->
    <button
      type="button"
      @click="togglePlay()"
      :aria-label="$store.player.playing ? '{UI.labels.pause}' : '{UI.labels.play}'"
      class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-terracotta text-soft-white focus-visible:ring-2 focus-visible:ring-warm-indigo focus-visible:outline-none"
    >
      <!-- Play icon -->
      <svg
        x-show="!$store.player.playing"
        class="ml-0.5 h-4 w-4"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M8 5v14l11-7z" />
      </svg>
      <!-- Pause icon -->
      <svg
        x-show="$store.player.playing"
        x-cloak
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
      </svg>
    </button>

    <!-- Episode title (truncated) -->
    <p class="min-w-0 flex-1 truncate text-sm font-medium text-deep-warm-brown" x-text="$store.player.slug.replace(/-/g, ' ')">
    </p>

    <!-- Elapsed time -->
    <span class="shrink-0 text-xs text-deep-warm-brown/50" x-text="formatTime($store.player.currentTime)">
      0:00
    </span>
  </div>
</div>
