---
/**
 * EpisodeCard — reusable card for episode listings.
 * Two variants via `size` prop:
 *  - "full"    → 16:9 thumbnail, category tag, title, excerpt, metadata, play indicator
 *  - "compact" → smaller thumbnail + title + play indicator
 */
import { formatDate } from '@/lib/format-date';

export interface Props {
  slug: string;
  title: string;
  description: string;
  publishDate: Date;
  duration: string;
  category: string;
  infographic: string;
  infographicAlt: string;
  size?: 'full' | 'compact';
  listened?: boolean;
}

const {
  slug,
  title,
  description,
  publishDate,
  duration,
  category,
  infographic,
  infographicAlt,
  size = 'full',
  listened = false,
} = Astro.props;

const href = `/episodi/${slug}/`;
const isCompact = size === 'compact';
---

<a
  href={href}
  class:list={[
    'group relative block overflow-hidden rounded-lg bg-soft-white shadow-sm transition-all hover:shadow-md',
    { 'hover:scale-[1.02]': !isCompact },
    { 'opacity-75': listened },
  ]}
  data-episode-card
  data-category={category}
>
  {isCompact ? (
    /* ── Compact variant ─────────────────────────────────────── */
    <div class="flex items-center gap-3 p-3">
      <div class="relative h-16 w-16 shrink-0 overflow-hidden rounded-md">
        <img
          src={infographic}
          alt={infographicAlt || ''}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="min-w-0 flex-1">
        <p class="truncate font-heading text-sm font-semibold text-deep-warm-brown group-hover:text-terracotta">
          {title}
        </p>
        <p class="text-xs text-deep-warm-brown/50">
          {duration}
        </p>
      </div>
      {/* Play indicator */}
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-terracotta/10 text-terracotta">
        {listened ? (
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
          </svg>
        ) : (
          <svg class="ml-0.5 h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
        )}
      </div>
    </div>
  ) : (
    /* ── Full variant ─────────────────────────────────────────── */
    <>
      <div class="relative aspect-video overflow-hidden">
        <img
          src={infographic}
          alt={infographicAlt || ''}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
        {/* Category tag overlay */}
        <span class="absolute top-3 left-3 rounded bg-warm-indigo/90 px-2 py-0.5 text-xs font-medium text-soft-white">
          {category}
        </span>
        {/* Listened badge */}
        {listened && (
          <span class="absolute top-3 right-3 flex h-6 w-6 items-center justify-center rounded-full bg-deep-warm-brown/60 text-soft-white">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
            </svg>
          </span>
        )}
      </div>
      <div class="p-4">
        <h3 class="mb-1 line-clamp-2 font-heading text-xl font-semibold text-deep-warm-brown group-hover:text-terracotta">
          {title}
        </h3>
        <p class="mb-2 text-sm text-deep-warm-brown/60">
          {formatDate(publishDate)} · {duration}
        </p>
        <p class="line-clamp-2 text-deep-warm-brown/80">
          {description}
        </p>
      </div>
    </>
  )}
</a>
