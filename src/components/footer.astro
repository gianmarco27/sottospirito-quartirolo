---
/**
 * Footer — site footer with semantic <footer> element.
 * Shows site name and minimal info.
 */
import { UI } from '@/lib/constants';
---

<footer class="mt-16 border-t border-warm-sand bg-parchment">
  <div class="mx-auto max-w-[var(--max-w-grid)] px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-2 text-center text-sm text-deep-warm-brown/50">
      <p class="font-heading font-semibold text-deep-warm-brown/70">
        {UI.site.name}
      </p>
      <p>{UI.site.description}</p>
    </div>
  </div>
</footer>
