---
/**
 * AltriEpisodiStrip — "Altri episodi" section displayed
 * below the episode body content.
 * Shows 2-3 compact EpisodeCard suggestions (chronological or same category).
 */
import EpisodeCard from '@/components/episode-card.astro';
import { UI } from '@/lib/constants';

export interface EpisodeItem {
  slug: string;
  title: string;
  description: string;
  publishDate: Date;
  duration: string;
  category: string;
  infographic: string;
  infographicAlt: string;
}

export interface Props {
  episodes: EpisodeItem[];
}

const { episodes } = Astro.props;
---

{episodes.length > 0 && (
  <section aria-label={UI.labels.otherEpisodes} class="mx-auto mt-12 max-w-[var(--max-w-reading)] border-t border-warm-sand pt-8">
    <h2 class="mb-6 font-heading text-2xl font-semibold">
      {UI.labels.otherEpisodes}
    </h2>
    <div class="space-y-3">
      {episodes.map((ep) => (
        <EpisodeCard
          slug={ep.slug}
          title={ep.title}
          description={ep.description}
          publishDate={ep.publishDate}
          duration={ep.duration}
          category={ep.category}
          infographic={ep.infographic}
          infographicAlt={ep.infographicAlt}
          size="compact"
        />
      ))}
    </div>
  </section>
)}
